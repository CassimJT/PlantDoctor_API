│   │   ├── local.strategy.mjs     # Email/password login
│   │   └── refresh.strategy.mjs   # Refresh token validation
│   │
│   ├── db.   mjs                     # Database connection (Mongo/Postgres)
│   
│   
│   
│
├── controllers/
│   ├── auth.controller.mjs        # Login, register, refresh tokens
│   ├── user.controller.mjs        # Profile management
│   ├── inference.controller.mjs   # Receive & fetch inference results
│   ├── device.controller.mjs      # Register & manage IoT devices
│   ├── telemetry.controller.mjs   # Receive sensor data from IoT devices
│   ├── dashboard.controller.mjs   # Aggregated stats for admin/app dashboard
│   └── admin.controller.mjs       # System-level actions
│
├── middleware/
