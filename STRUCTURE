│   ├── inference.routes.mjs       # /api/inference/*
│   ├── device.routes.mjs          # /api/devices/*
│   ├── telemetry.routes.mjs       # /api/telemetry/*
│   └── admin.routes.mjs           # /api/admin/*
│
├── utils/
│   ├── jwt.mjs                    # JWT sign / verify helpers
│   ├── password.mjs               # Hash & compare passwords
│   ├── validators.mjs             # Joi/Zod validation schemas
│   ├── constants.mjs              # Status codes & system constants
│   └── helper.mjs                 # General utility helpers
